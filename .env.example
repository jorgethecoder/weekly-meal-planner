# Recipe API Configuration
# Sign up at https://spoonacular.com/food-api to get a free API key.
# If left blank, the app will run in MOCK MODE with curated recipes.
RECIPE_API_KEY=

# Gmail SMTP Configuration
# Enter your Gmail address and a generated 16-character Gmail App Password.
# Note: Do NOT use your primary password; follow instructions to create an App Password.
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Recipient Email (Optional: Defaults to GMAIL_USER if not set)
RECIPIENT_EMAIL=recipient_email@example.com
